###############################################################################
# Minty-I3 Configuration File
# Linux Mint Dark Theme i3 Window Manager
###############################################################################

set $mod Mod4
set $alt Mod1

# Linux Mint Dark Theme Colors
set $bg #1a1a1a
set $fg #ffffff
set $accent #87cf3e
set $border #2d2d2d
set $urgent #e74c3c

# Window colors
client.focused          #87cf3e #1a1a1a #ffffff #87cf3e #87cf3e
client.focused_inactive #2d2d2d #1a1a1a #e0e0e0 #2d2d2d #2d2d2d
client.unfocused        #2d2d2d #1a1a1a #888888 #2d2d2d #2d2d2d
client.urgent           #e74c3c #1a1a1a #ffffff #e74c3c #e74c3c

font pango:DejaVu Sans 10

# Workspace names
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# Floating
floating_modifier $mod
default_border pixel 2
gaps inner 8
gaps outer 4

# Keybindings 
bindsym $mod+Return exec --no-startup-id xfce4-terminal
bindsym $mod+Shift+Return exec --no-startup-id xfce4-terminal --drop-down
bindsym $mod+Shift+q kill
bindsym $mod+d exec --no-startup-id rofi -show drun -theme windows10
bindsym $mod+Shift+d exec --no-startup-id rofi -show run -theme windows10
bindsym $mod+Shift+e exec --no-startup-id i3-nagbar -t warning -m 'Exit i3?' -B 'Yes' 'i3-msg exit'
bindsym $mod+Shift+question exec --no-startup-id ~/.config/i3/show-shortcuts.sh
bindsym $mod+F1 exec --no-startup-id ~/.config/i3/show-shortcuts.sh

# Focus - (vim keys + arrows)
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Move 
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Layout 
bindsym $mod+b splith
bindsym $mod+v splitv
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle

# Scratchpad
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

# Focus parent/child
bindsym $mod+a focus parent
bindsym $mod+c focus child

# Workspaces
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# Move to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# Reload/restart 
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+s exec --no-startup-id systemctl suspend
bindsym $mod+Shift+Ctrl+s exec --no-startup-id systemctl hibernate
bindsym $mod+Shift+l exec --no-startup-id i3lock -c 000000
bindsym $mod+Shift+Ctrl+l exec --no-startup-id systemctl poweroff
bindsym $mod+Shift+Ctrl+r exec --no-startup-id systemctl reboot

# Media keys with visual notifications
# Volume up - shows notification with current level
bindsym XF86AudioRaiseVolume exec --no-startup-id bash -c 'pactl set-sink-volume @DEFAULT_SINK@ +5%; CURRENT=$(pactl list sinks | grep "^\s*Volume:" | head -n 1 | sed "s/.* \([0-9]*\)%.*/\1/"); notify-send -t 1000 "Volume" "Level: ${CURRENT}%"'

# Volume down - shows notification with current level
bindsym XF86AudioLowerVolume exec --no-startup-id bash -c 'pactl set-sink-volume @DEFAULT_SINK@ -5%; CURRENT=$(pactl list sinks | grep "^\s*Volume:" | head -n 1 | sed "s/.* \([0-9]*\)%.*/\1/"); notify-send -t 1000 "Volume" "Level: ${CURRENT}%"'

# Mute toggle - shows notification with status
bindsym XF86AudioMute exec --no-startup-id bash -c 'pactl set-sink-mute @DEFAULT_SINK@ toggle; MUTE=$(pactl list sinks | grep "^\s*Mute:" | head -n 1 | sed "s/.*Mute: \(.*\)/\1/"); if [ "$MUTE" = "yes" ]; then notify-send -t 1000 "Volume" "Muted"; else notify-send -t 1000 "Volume" "Unmuted"; fi'

# Media playback controls
bindsym XF86AudioPlay exec --no-startup-id playerctl play-pause
bindsym XF86AudioNext exec --no-startup-id playerctl next
bindsym XF86AudioPrev exec --no-startup-id playerctl previous

# Brightness up - shows notification with current level
bindsym XF86MonBrightnessUp exec --no-startup-id bash -c 'brightnessctl set +5%; CURRENT=$(brightnessctl get); MAX=$(brightnessctl max); PERCENT=$((CURRENT * 100 / MAX)); notify-send -t 1000 "Brightness" "Level: ${PERCENT}%"'

# Brightness down - shows notification with current level
bindsym XF86MonBrightnessDown exec --no-startup-id bash -c 'brightnessctl set 5%-; CURRENT=$(brightnessctl get); MAX=$(brightnessctl max); PERCENT=$((CURRENT * 100 / MAX)); notify-send -t 1000 "Brightness" "Level: ${PERCENT}%"'
bindsym Print exec --no-startup-id scrot $HOME/Screenshots/%Y-%m-%d-%H-%M-%S.png
bindsym $mod+Print exec --no-startup-id scrot -u $HOME/Screenshots/%Y-%m-%d-%H-%M-%S.png
bindsym $mod+Shift+Print exec --no-startup-id scrot -s $HOME/Screenshots/%Y-%m-%d-%H-%M-%S.png

# Resize mode
mode "resize" {
    bindsym Left resize shrink width 10 px or 10 ppt
    bindsym Down resize grow height 10 px or 10 ppt
    bindsym Up resize shrink height 10 px or 10 ppt
    bindsym Right resize grow width 10 px or 10 ppt
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# Bar configuration
bar {
    position bottom
    status_command i3status
    colors {
        background #1a1a1a
        statusline #ffffff
        separator #87cf3e
        focused_workspace  #87cf3e #1a1a1a #ffffff
        active_workspace   #2d2d2d #1a1a1a #e0e0e0
        inactive_workspace #1a1a1a #1a1a1a #888888
        urgent_workspace   #e74c3c #1a1a1a #ffffff
    }
}

# Multi-Monitor Workspace Configuration
# Workspaces are tied to specific monitors (workspace autonomy)
# Use xrandr to identify your monitor names and customize as needed

# Example: Bind workspaces to specific outputs
# workspace $ws1 output HDMI-1
# workspace $ws2 output HDMI-1
# workspace $ws3 output DP-1
# workspace $ws4 output DP-1

# Move workspaces between monitors
bindsym $mod+Shift+greater move workspace to output right
bindsym $mod+Shift+less move workspace to output left

# Focus monitors
bindsym $mod+comma focus output left
bindsym $mod+period focus output right

# Window Rules for Common Applications
# Floating windows
for_window [class="Pavucontrol"] floating enable
for_window [class="Lxappearance"] floating enable
for_window [class="Nm-connection-editor"] floating enable
for_window [class="Blueman-manager"] floating enable
for_window [class="Xarchiver"] floating enable
for_window [window_role="pop-up"] floating enable
for_window [window_type="dialog"] floating enable

# Application Workspace Assignments
assign [class="Firefox"] $ws1
assign [class="Chromium"] $ws1
assign [class="Thunderbird"] $ws2
assign [class="Evolution"] $ws2
assign [class="Code"] $ws3
assign [class="VSCodium"] $ws3
assign [class="xfce4-terminal"] $ws4
assign [class="Thunar"] $ws5
assign [class="Nemo"] $ws5
assign [class="Spotify"] $ws6
assign [class="Discord"] $ws7
assign [class="Steam"] $ws8

# Startup applications - using autostart script
exec --no-startup-id ~/.config/i3/autostart.sh

# Show notification that Minty-I3 is loaded (visual confirmation)
exec --no-startup-id sleep 2 && notify-send "Minty-I3 Loaded" "Linux Mint Dark Theme Active" -i dialog-information

# Cinnamon Integration (optional)
# These services run in the background for better Mint integration
# Uncomment if using Cinnamon-Flashback session
# exec --no-startup-id /usr/bin/cinnamon-settings-daemon
# exec --no-startup-id /usr/lib/x86_64-linux-gnu/cinnamon-settings-daemon/csd-xrandr
# exec --no-startup-id /usr/lib/x86_64-linux-gnu/cinnamon-settings-daemon/csd-keyboard
